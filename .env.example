# ----- Static login credentials -----
# Used by the demo login. Change these to your own values.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Secret value stored in the session cookie. Use a long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-string

# ----- Database (Vercel Postgres / Neon) -----
# Vercel injects POSTGRES_URL automatically when you attach the DB.
# For local dev, paste the connection string from the Vercel/Neon dashboard.
# pgAdmin uses the SAME connection details (host/db/user/password/port).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
